# =========================================================
# .env.example — Safe to commit (no real secrets here)
# Copy this to .env and fill in your values.
# All Vite env vars MUST start with VITE_ to be accessible.
# =========================================================

# Base URL for the site (automatically set by vite.config.js — no need to change)
# VITE_BASE_URL=/jewellery-site/

# Example: your WhatsApp API or contact link
# VITE_WHATSAPP_NUMBER=919876543210

# Example: your Instagram handle
# VITE_INSTAGRAM_HANDLE=pearlyn_accessories

# Example: a public API endpoint (safe to expose)
# VITE_API_URL=https://api.example.com

# ⚠️  NEVER put real secrets (tokens, passwords) in .env files
#     that get committed to version control.
#     For GitHub Pages (static sites), there is NO real backend,
#     so keep sensitive data server-side only.
